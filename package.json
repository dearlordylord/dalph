{
  "name": "@dalph/root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": "^22.22.2 || ^24.15.0",
    "pnpm": ">=10.29.0"
  },
  "scripts": {
    "prepare": "husky",
    "build": "pnpm --filter './packages/**' --if-present run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "pnpm lint:code && pnpm check:duplicates",
    "lint:code": "eslint 'src/**/*.{ts,tsx}' 'packages/**/*.{ts,tsx}' 'scripts/**/*.{ts,mjs}' 'test/**/*.{ts,tsx}' '*.config.{ts,mjs}' --no-error-on-unmatched-pattern --max-warnings 0",
    "lint:fix": "pnpm lint:code --fix",
    "format": "pnpm lint:code --fix",
    "check:format": "pnpm lint:code",
    "check:circular": "node scripts/check-circular.mjs",
    "check:duplicates": "jscpd .",
    "check:quint": "pnpm quint typecheck specs/taskWorkSessionRecovery.qnt && pnpm quint test specs/taskWorkSessionRecovery_test.qnt --main taskWorkSessionRecoveryTest && pnpm quint run specs/taskWorkSessionRecovery.qnt --invariants requestRequiresIntent everyRequestUsesStableIdentity everyRequestUsesStablePayload causalPredecessorsAreStable absenceAloneAuthorizesRepeat unreadableAndConflictNeverAuthorize establishmentRequiresMatchingReport lookupBoundIsRespected terminalOutcomeIsStable --witnesses intentReached requestReached absenceAuthorizedRepeatReached matchingReached outcomeReached unreadableBoundReached absenceBoundReached conflictReached crashRestartReached --max-steps 40 --max-samples 10000 --verbosity 1",
    "check:secrets": "gitleaks git --redact --no-banner",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "check:all": "node scripts/run-quality-gate.mjs"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix --max-warnings 0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "fs-ext-extra-prebuilt",
      "msgpackr-extract",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@dalph/orchestrator": "workspace:*",
    "@effect/eslint-plugin": "0.3.2",
    "@effect/language-service": "0.87.0",
    "@effect/vitest": "4.0.0-beta.99",
    "@eslint/compat": "2.0.2",
    "@eslint/js": "9.39.5",
    "@firfi/quint-connect": "2.0.2-effect4.1",
    "@informalsystems/quint": "0.32.0",
    "@types/node": "26.1.1",
    "@typescript-eslint/parser": "8.65.0",
    "@vitest/coverage-v8": "4.0.18",
    "effect": "4.0.0-beta.99",
    "eslint": "9.39.2",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-functional": "9.0.2",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-import-x": "4.16.1",
    "eslint-plugin-sort-destructure-keys": "2.0.0",
    "fast-check": "4.9.0",
    "husky": "9.1.7",
    "jscpd": "4.0.8",
    "lint-staged": "16.2.7",
    "madge": "8.0.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0",
    "vitest": "4.0.18",
    "zod": "4.1.12"
  }
}
